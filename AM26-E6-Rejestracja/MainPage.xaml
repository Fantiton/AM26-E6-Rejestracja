<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AM26_E6_Rejestracja.MainPage">

    <ScrollView>
        <VerticalStackLayout>
            <Label Text="Rejestuj konto"/>
            <Label Text="Podaj e-mail:"/>
            <Entry x:Name="emailEntry" Placeholder="email"/>
            <Label Text="Podaj hasło"/>
            <Entry x:Name="passwordEntry" IsPassword="True"/>
            <Label Text="Powtórz hasło"/>
            <Entry x:Name="repeatPasswordEntry" IsPassword="True"/>
            <Button x:Name="ConfirmButton" Text="ZATWIERDŹ" HorizontalOptions="Center"/>
            <Label x:Name="outputLabel" HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
