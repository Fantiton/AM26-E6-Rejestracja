<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AM26_E6_Rejestracja.MainPage">

    <ScrollView>
        <VerticalStackLayout BackgroundColor="LightGray">
            <Label Text="Rejestuj konto" BackgroundColor="Teal" TextColor="White" FontSize="Large"/>
            <Label Text="Podaj e-mail:"/>
            <Entry x:Name="emailEntry" Placeholder="email" HorizontalOptions="FillAndExpand" BackgroundColor="White"/>
            <Label Text="Podaj hasło"/>
            <Entry x:Name="passwordEntry" IsPassword="True" HorizontalOptions="FillAndExpand" BackgroundColor="White"/>
            <Label Text="Powtórz hasło"/>
            <Entry x:Name="repeatPasswordEntry" IsPassword="True" HorizontalOptions="FillAndExpand" BackgroundColor="White"/>
            <Button x:Name="ConfirmButton" Text="ZATWIERDŹ" HorizontalOptions="Center" BackgroundColor="Gray" Clicked="ConfirmButton_Clicked"/>
            <Label x:Name="outputLabel" HorizontalOptions="Center" Text="Autor: Musztardowy Potwór"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
